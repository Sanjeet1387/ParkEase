<% layout("layouts/boilerplate") %>
<div class="cols-8 offset-2 mt-3">
    <h3>Udate your ParkingSpot: <b><%= parkingspot.title %></b></h3><br/>
    <form method="post" action="/parkingspots/<%= parkingspot._id %>?_method=PUT" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="title" class="form-label">Title: </label>
            <input 
                type="text" 
                name="parkingspot[title]"
                value="<%= parkingspot.title %>"
                id="title"
                class="form-control"
                required
            >
            <div class="invalid-feedback">title required</div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description:</label><br/>
            <textarea
                rows="4"
                cols="30"
                name="parkingspot[description]"
                id="description"
                class="form-control"
                required
            >
            <%= parkingspot.description %> 
            </textarea>
            <div class="invalid-feedback">description required</div>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Upload Image Url: </label><br/>
            <input 
                type="url" 
                name="parkingspot[image][url]"
                value="<%= parkingspot.image.url %>"
                id="image"
                class="form-control"
            >
        </div>
        <div class="mb-3">
            <label for="address" class="form-label">Address:</label><br/>
            <textarea
                rows="3"
                cols="20"
                name="parkingspot[location][address]"
                id="address"
                class="form-control"
                required
            >
            <%= parkingspot.location.address %> 
            </textarea>
            <div class="invalid-feedback">address required</div>
        </div>
        <div class="mb-3">
            <label for="city" class="form-label">City: </label>
            <input 
                type="text" 
                name="parkingspot[location][city]"
                value="<%= parkingspot.location.city %>"
                id="city"
                class="form-control"
                required
            >
            <div class="invalid-feedback">city required</div>
        </div>
        <div class="mb-3">
            <label for="state" class="form-label">State: </label>
            <input 
                type="text" 
                name="parkingspot[location][state]"
                value="<%= parkingspot.location.state %>"
                id="state"
                class="form-control"
                required
            >
            <div class="invalid-feedback">city required</div>
        </div>
        <div class="mb-3">
            <label for="country" class="form-label">Country: </label>
            <input 
                type="text" 
                name="parkingspot[location][country]"
                value="<%= parkingspot.location.country %>"
                id="country"
                class="form-control"
                required
            >
            <div class="invalid-feedback">country name required</div>
        </div>
        <div class="mb-3">
            <label for="price" class="form-label">Price: </label>
            <input 
                type="number" 
                name="parkingspot[price]" 
                value="<%= parkingspot.price %>"
                id="price"
                class="form-control"
                required
            >
            <div class="invalid-feedback">price required</div>
        </div>
        <br/>
        <button class="btn dark-btn update-btn mb-3">Update</button>
    </form>
</div>